# Corvus v1.0 — environment variables
# Copy this file to .env and fill in all values before running.
# CRITICAL: Never commit a populated .env to version control.
# F-06 FIX: .gitignore now exists — but always double-check with `git status` before pushing.

# ── Required: signing & access ────────────────────────────────────────────────
CORVUS_EXECUTOR_PRIVATE_KEY=0x...          # Hot wallet private key (hex, with 0x prefix)
CORVUS_COLD_WALLET=0x...                   # Cold wallet address (sweep destination)
CORVUS_FLASH_EXECUTOR_ADDRESS=0x...        # FlashExecutor contract address (post-deploy)

# ── Required: deployment ──────────────────────────────────────────────────────
# AUDIT 4.1: OWNER_ADDRESS should be a Gnosis Safe / hardware wallet — it holds
# whitelist + sweep-to-any + executor-rotation power and is immutable after deploy.
# The DEPLOYER key gets NO rights on the contract; it only pays deploy gas.
OWNER_ADDRESS=0x...                        # Contract owner (SET TO A MULTISIG)
COLD_WALLET_ADDRESS=0x...                  # Passed to Deploy.s.sol constructor
EXECUTOR_ADDRESS=0x...                     # Passed to Deploy.s.sol constructor
DEPLOYER_PRIVATE_KEY=...                   # uint256, used only during contract deploy (no on-chain rights)

# ── Required: verification ────────────────────────────────────────────────────
BASESCAN_API_KEY=...                       # BaseScan API key for contract verification

# ── Required: node ────────────────────────────────────────────────────────────
BASE_RPC_URL=https://...                   # HTTP RPC (used by forge test --fork-url)
L1_RPC_URL=https://...                     # Ethereum L1 RPC (for op-node)

# ── Required: Telegram alerts (F-09 FIX) ─────────────────────────────────────
# Without these, the operator receives NO real-time alerts for panics, HF drops,
# gas exhaustion, or circuit breaker trips. Get these from @BotFather on Telegram.
CORVUS_TELEGRAM_BOT_TOKEN=...             # e.g. 123456789:ABC-DEFghijklmno
CORVUS_TELEGRAM_CHAT_ID=...              # e.g. -100123456789 (negative = group chat)

# ── Optional overrides ────────────────────────────────────────────────────────
# CORVUS_ETH_PRICE_FALLBACK_USD=2500.0     # Seed price before first Chainlink update
# CORVUS_JIT_ENABLED=false                 # S4 Flash JIT — keep false until rebuilt (AUDIT 2.9)
# CORVUS_RATE_ARB_OPEN_ENABLED=false       # S5 opening — keep false until Morpho carry impl (AUDIT 2.5)
# (S6 Backrun and S7 Pendle were removed — their env vars no longer exist.)

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=...                       # Grafana admin password (required — no default)
